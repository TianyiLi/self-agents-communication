# Telegram Bot Tokens (from @BotFather, one per agent)
FRONTEND_BOT_TOKEN=123456:ABC-DEF
BACKEND_BOT_TOKEN=789012:GHI-JKL

# Security: optional first-boot seed for the group allowlist.
# After seeding, the source of truth is a Redis Set (`agent:<id>:allowed_chats`)
# managed via /allow_here, /disallow_here, /allowed in Telegram.
# Leave empty to skip seeding — empty allowlist preserves legacy "allow all".
ALLOWED_CHAT_IDS=

# Agent identity and infra config are in docker-compose.yml per service.
# These are only needed for local dev without Docker:
# AGENT_ID=frontend-agent
# AGENT_NAME=frontend-agent
# AGENT_ROLE=前端開發
# AGENT_DESC=負責 React 前端專案
# AGENT_CAPS=react,typescript,css
# AGENT_PROJECT=/path/to/project
# BOT_TOKEN=123456:ABC-DEF
# REDIS_URI=redis://localhost:6379
# MCP_PORT=3101
