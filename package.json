{
  "name": "self-agents-communication",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun ./src/index.ts",
    "dev": "bun --watch ./src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/channel.ts --compile --outfile dist/agent-channel",
    "install:bin": "bun scripts/install.ts",
    "uninstall:bin": "bun scripts/uninstall.ts"
  },
  "devDependencies": {
    "@types/bun": "1.2.5"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@grammyjs/hydrate": "^1.4.1",
    "@grammyjs/parse-mode": "^1.10.0",
    "@modelcontextprotocol/sdk": "1.28.0",
    "consola": "^3.3.3",
    "grammy": "1.30.0",
    "redis": "^4.7.0",
    "zod": "^3.24.0"
  }
}
